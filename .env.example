# API server (run with `npm run dev` — starts Vite + server)
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Supabase — shared cards + GitHub card cache/percentiles (optional locally)
# Without it: resume shares use in-memory store; GitHub cards still work in RAM (no percentiles).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional — higher GitHub API rate limit for /api/gh and GitHub mode
# GITHUB_TOKEN=

# Canonical public URL (set on Railway before build for correct QR + README snippets)
# VITE_PUBLIC_SITE_URL=https://resumerpg.app
# Same URL for PNG card footer text (runtime on server)
# PUBLIC_SITE_URL=https://resumerpg.app

# Production settings
# NODE_ENV=production
# PORT=8787
# ALLOWED_ORIGINS=https://resumerpg.app,https://www.resumerpg.app
# RATE_LIMIT_GENERATE=10
# RATE_LIMIT_SHARE=30
